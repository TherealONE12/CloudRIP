{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CloudRip",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/cloudrip",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Pretty-printing aktivieren",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Disassembly flavor",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build CloudRip"
    }
  ]
}